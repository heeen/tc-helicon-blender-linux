# TC Helicon / TC Electronic USB audio devices
# Grant permissions and run init sequence before snd-usb-audio binds.

# Blender - grant permissions on the USB device node
SUBSYSTEM=="usb", ATTR{idVendor}=="1220", ATTR{idProduct}=="8fe1", MODE="0666"

# Blender - run init and then bind snd-usb-audio for each audio interface
# The RUN script fires after the device is enumerated but (with the driver
# unbind below) before the audio driver has probed, so we can init first.
SUBSYSTEM=="usb", ATTR{idVendor}=="1220", ATTR{idProduct}=="8fe1", ACTION=="add", RUN+="/usr/local/bin/blender-ctl-udev-init %k"

# GoXLR
SUBSYSTEM=="usb", ATTR{idVendor}=="1220", ATTR{idProduct}=="8fe0", MODE="0666"
# GoXLR Mini
SUBSYSTEM=="usb", ATTR{idVendor}=="1220", ATTR{idProduct}=="8fe4", MODE="0666"

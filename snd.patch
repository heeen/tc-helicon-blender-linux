+/*
+ * TC Helicon Blender, GoXLR, GoXLR Mini
+ * These devices require a vendor-specific init sequence to activate their
+ * UAC2 audio interface. Without it, the firmware does not respond to
+ * USB Audio Class clock source queries (CS_RANGE, GET_CUR), causing
+ * parse_audio_format_rates_v2v3() to fail during driver probe.
+ *
+ * The sequence was determined by USB-sniffing the Windows driver (Thesycon
+ * TUSBAudio) and matches the goxlr-utility Linux initialiser.
+ */
+/*
+ * TC Helicon GoXLR, Blender, and GoXLR Mini need a vendor-specific
+ * init sequence to activate USB audio streaming.  Without this the
+ * device exposes UAC2 descriptors but isochronous transfers fail.
+ *
+ * The sequence was determined by observing the Windows driver
+ * (Thesycon TUSBAudio) and the GoXLR Utility project:
+ *   1. Vendor read  0x00 — wakes up the vendor control interface
+ *   2. UAC2 SET_CUR — sets sample rate to 48 kHz on clock source 41
+ *   3. Vendor write 0x01 — "activate" command
+ *   4. 1 s sleep    — firmware needs time to set up isochronous endpoints
+ *   5. Vendor read  0x03 — reads (and discards) device state
+ *
+ * No USB reset is required; the device applies the configuration
+ * in-place, so we return 0 and normal probe continues.
+ */
+static int snd_usb_tc_helicon_boot_quirk(struct usb_device *dev)
+{
+	int ret;
+	u8 buf[24];
+
+	/* Step 1: vendor read to wake up vendor control interface */
+	ret = snd_usb_ctl_msg(dev, usb_rcvctrlpipe(dev, 0), 0x00,
+			      USB_DIR_IN | USB_TYPE_VENDOR | USB_RECIP_INTERFACE,
+			      0, 0, buf, sizeof(buf));
+	if (ret < 0)
+		dev_warn(&dev->dev,
+			 "TC Helicon boot quirk: vendor read failed %d\n", ret);
+
+	/* Step 2: set sample rate to 48 kHz (UAC2 SET_CUR on clock 41) */
+	buf[0] = 0x80;	/* 48000 in LE */
+	buf[1] = 0xbb;
+	buf[2] = 0x00;
+	buf[3] = 0x00;
+	ret = snd_usb_ctl_msg(dev, usb_sndctrlpipe(dev, 0), UAC_SET_CUR,
+			      USB_DIR_OUT | USB_TYPE_CLASS | USB_RECIP_INTERFACE,
+			      0x0100, /* UAC2_CS_CONTROL_SAM_FREQ << 8 */
+			      0x2900, buf, 4);
+	if (ret < 0) {
+		dev_err(&dev->dev,
+			"TC Helicon boot quirk: SET_CUR failed %d\n", ret);
+		return ret;
+	}
+
+	/* Step 3: vendor write "activate" command */
+	ret = snd_usb_ctl_msg(dev, usb_sndctrlpipe(dev, 0), 0x01,
+			      USB_DIR_OUT | USB_TYPE_VENDOR | USB_RECIP_INTERFACE,
+			      0, 0, NULL, 0);
+	if (ret < 0)
+		dev_warn(&dev->dev,
+			 "TC Helicon boot quirk: activate failed %d\n", ret);
+
+	/* Step 4: firmware needs time to configure isochronous endpoints */
+	msleep(1000);
+
+	/* Step 5: vendor read to finalize init (response discarded) */
+	ret = snd_usb_ctl_msg(dev, usb_rcvctrlpipe(dev, 0), 0x03,
+			      USB_DIR_IN | USB_TYPE_VENDOR | USB_RECIP_INTERFACE,
+			      0, 0, buf, 16);
+	if (ret < 0)
+		dev_warn(&dev->dev,
+			 "TC Helicon boot quirk: state read failed %d\n", ret);
+
+	return 0;
+}

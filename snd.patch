 			     struct usb_interface *intf,
 			     const struct snd_usb_audio_quirk *quirk,
@@ -1682,6 +1758,10 @@ int snd_usb_apply_boot_quirk_once(struct usb_device *dev,
 	switch (id) {
 	case USB_ID(0x07fd, 0x0008): /* MOTU M Series, 1st hardware version */
 		return snd_usb_motu_m_series_boot_quirk(dev);
+	case USB_ID(0x1220, 0x8fe0): /* TC Helicon GoXLR */
+	case USB_ID(0x1220, 0x8fe1): /* TC Helicon Blender */
+	case USB_ID(0x1220, 0x8fe4): /* TC Helicon GoXLR Mini */
+		return snd_usb_tc_helicon_boot_quirk(dev);
 	}
 
 	return 0;
